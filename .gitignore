# ----------------------------------------------------------------------------
# Core Rust / Cargo (核心构建产物 - 必须忽略)
# ----------------------------------------------------------------------------
# 巨大的构建目录，包含所有 .o, .rmeta, .rlib, .exe 等中间产物
target/
# Cargo 自动生成的用于调试的文件
**/*.rs.bk

# ----------------------------------------------------------------------------
# IDE & Editors (编辑器配置)
# ----------------------------------------------------------------------------
# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# IntelliJ / RustRover
.idea/
*.iml

# Vim / Emacs (如果你以后变强了可能会用到)
*~
*.swp
*.swo

# ----------------------------------------------------------------------------
# Operating System (系统垃圾文件)
# ----------------------------------------------------------------------------
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/


# ----------------------------------------------------------------------------
# Bazel (针对你的构建系统)
# ----------------------------------------------------------------------------
# Bazel 在构建时生成的符号链接文件夹
bazel-*
# 用户的本地 Bazel 配置
user.bazelrc

# ----------------------------------------------------------------------------
# Manual Compilations (手动 rustc 编译产生的垃圾)
# ----------------------------------------------------------------------------
# 如果你手动运行 rustc main.rs，会在根目录生成这些文件
*.exe
*.pdb
*.lib

